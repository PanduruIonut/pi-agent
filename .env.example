ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Comma-separated list of Telegram chat IDs allowed to use the bot
# Get your chat ID by messaging @userinfobot on Telegram
TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321

# Web API (set API_ENABLED=false to disable)
API_ENABLED=true
API_HOST=0.0.0.0
API_PORT=9000
# Secret key required in the X-API-Key header for all requests
API_KEY=change_me_to_something_secret

# Hour of day (0-23) to send the daily summary (default: 8 = 8am)
SUMMARY_HOUR=8
